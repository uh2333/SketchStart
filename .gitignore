# ==========================
# 1. 构建输出目录
# ==========================
/dist/
/build/
/out/
/target/

# ==========================
# 2. 可执行文件（Windows/Linux/macOS）
# ==========================
*.exe
*.dll
*.so
*.dylib
*.bin
*.out
*.spec

# ==========================
# 3. 忽略 . 开头的文件和目录（排除必需的 .gitignore 等）
# ==========================
.*
!.gitignore
!.gitattributes
!.gitmodules
!.gitkeep

# ==========================
# 4. 临时目录（根目录下的 temp）
# ==========================
/temp/

# ==========================
# 5. 指定文件（路径使用正斜杠）
# ==========================
data/plugins/plugin-manager/main0.js
data/plugins/plugin-manager/backend0.py
structure.txt
temp_说明文档
# ==========================
# 6. 常见系统垃圾文件（git 本身推荐的通用忽略）
# ==========================
Thumbs.db
.DS_Store
*.swp
*.swo
*~
*.log
*.tmp
# ==========================
# Python 缓存文件
# ==========================
__pycache__/
*.pyc
*.pyo